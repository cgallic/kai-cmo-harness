# =============================================================================
# CMO AGENT SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# API KEYS - THIRD PARTY SERVICES
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxx
APOLLO_API_KEY=your-apollo-key
CLICKUP_API_TOKEN=pk_xxx
CLICKUP_WORKSPACE_ID=12345678
GEMINI_API_KEY=AIzaSyxxx
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_TIKTOK_HOST=tiktok-api23.p.rapidapi.com

# Email Services
RESEND_API_KEY=re_xxx
LOOPS_API_KEY=your-loops-key

# =============================================================================
# SUPABASE DATABASES
# =============================================================================
# Add your Supabase projects here
# Format: {PROJECT}_SUPABASE_URL and {PROJECT}_SUPABASE_KEY

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxx

# =============================================================================
# GOOGLE ANALYTICS 4 - PROPERTY IDS
# =============================================================================
# Format: GA_{SITE_KEY}_PROPERTY_ID
# Get property ID from GA4 Admin > Property Settings

GA_YOURSITE_PROPERTY_ID=123456789

# Path to Google service account credentials JSON
GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json

# =============================================================================
# GOOGLE SEARCH CONSOLE - SITE URLS
# =============================================================================
# Format: GSC_{SITE_KEY}_URL
# Use sc-domain: prefix for domain properties

GSC_YOURSITE_URL=sc-domain:yoursite.com

# =============================================================================
# META / FACEBOOK ADS
# =============================================================================
META_ACCESS_TOKEN=your-access-token
META_AD_ACCOUNT_ID=act_123456789

# =============================================================================
# LINKEDIN ADS - CONVERSIONS API
# =============================================================================
# Direct API access token for LinkedIn Conversions API
# Generate at: Campaign Manager > Measurement > Conversion Tracking > Direct API
LINKEDINADS_ACCESS_TOKEN=your-linkedin-access-token

# =============================================================================
# SITE REGISTRY (JSON)
# =============================================================================
# Configure your sites as a JSON object
# Each site needs: name, url, category (product/client/personal/leadgen)

SITES_CONFIG={"yoursite":{"name":"Your Site","url":"https://yoursite.com","category":"product"}}

# =============================================================================
# WEBHOOK GATEWAY
# =============================================================================
# API key for authenticating webhook requests (generate with: openssl rand -hex 32)
CMO_GATEWAY_API_KEY=your-secure-api-key-here

# Gateway server configuration
CMO_GATEWAY_HOST=0.0.0.0
CMO_GATEWAY_PORT=8088
CMO_GATEWAY_DEBUG=false

# =============================================================================
# AUTONOMOUS AGENT
# =============================================================================

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# Your WhatsApp number for receiving notifications
AGENT_OWNER_PHONE=+1234567890

# Model Configuration
AGENT_DEFAULT_MODEL=claude-3-5-haiku-20241022
AGENT_OPUS_MODEL=claude-opus-4-5-20251101
AGENT_HAIKU_MODEL=claude-3-5-haiku-20241022

# Agent Behavior
AGENT_POLLING_INTERVAL=60
AGENT_MAX_CONCURRENT_TASKS=3
AGENT_TASK_TIMEOUT=300
AGENT_RETRY_ATTEMPTS=3
AGENT_RETRY_DELAY=60

# Notifications
AGENT_NOTIFY_ON_FAILURE=true
AGENT_NOTIFY_ON_APPROVAL=true
AGENT_DAILY_SUMMARY=true

# Feature Flags
AGENT_WHATSAPP_ENABLED=true
AGENT_SCHEDULER_ENABLED=true

# =============================================================================
# KAI CALLS - Business Manager Agent
# =============================================================================

# Supabase (service role for direct DB reads)
KAICALLS_SUPABASE_URL=https://xxx.supabase.co
KAICALLS_SUPABASE_KEY=eyJxxx

# Kai Calls API (for action endpoints: email sends, Vapi updates)
KAICALLS_API_URL=https://kaicalls.com
KAICALLS_SERVICE_KEY=your-agent-service-key
