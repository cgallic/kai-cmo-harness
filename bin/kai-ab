#!/usr/bin/env bash
# kai-ab — A/B test tracking and analysis.
# Usage: kai-ab create "test-name" --variants "A,B,C" --metric cvr
# Usage: kai-ab record <test-id> --variant A --impressions 1000 --clicks 45 --conversions 8
# Usage: kai-ab analyze <test-id>
# Usage: kai-ab list [--status running|significant|insufficient_data]
set -euo pipefail

KAI_ROOT="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/.." && pwd)"
export PYTHONPATH="${KAI_ROOT}:${PYTHONPATH:-}"

source "${KAI_ROOT}/lib/find-python.sh"
exec "$PYTHON" "${KAI_ROOT}/scripts/content/ab_cli.py" "$@"
